# px credential template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to your px config directory and fill in real values:
#
#   Linux / macOS : ~/.config/proxy-launcher/.env
#   Windows       : %APPDATA%\proxy-launcher\.env
#
# NEVER commit the real .env file to version control.
# Add it to .gitignore:  echo ".env" >> ~/.config/proxy-launcher/.gitignore
# ─────────────────────────────────────────────────────────────────────────────

PX_PROXY_USER=your_username
PX_PROXY_PASS=your_password
